# Tagesmutter finden - Cache-Steuerung + sprechende URLs (SEO)
# HTML/CSS/JS immer frisch; Bilder/Fonts duerfen cachen.

<IfModule mod_headers.c>
    <FilesMatch "\.(html|php|css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

AddDefaultCharset UTF-8

# Startseite server-seitig gerendert (SEO): index.php vor index.html
DirectoryIndex index.php index.html

# Sprechende URLs (SEO) - OHNE <IfModule>-Wrapper, damit LiteSpeed (Hostinger) die Regeln anwendet
RewriteEngine On

# Alte .html-Adressen dauerhaft umleiten (Bookmarks / Suchindex)
RewriteCond %{QUERY_STRING} (^|&)id=([a-z0-9\-]+)
RewriteRule ^profil\.html$ /profil/%2? [R=301,L]
RewriteRule ^index\.html$ / [R=301,L]

# Sprechende Stadt-Landingpages: /tagesmutter/<stadt> -> stadt.php
RewriteRule ^tagesmutter/([a-z0-9-]+)/?$ stadt.php?stadt=$1 [L,QSA]

# Sprechende Profil-URLs: /profil/<id> -> profil.php
RewriteRule ^profil/([a-z0-9-]+)/?$ profil.php?id=$1 [L,QSA]

ErrorDocument 404 /404.html
