# Tagesmutter finden – Cache-Steuerung
# Ziel: HTML/CSS/JS immer frisch (Updates kommen sofort an), Bilder/Fonts dürfen cachen.

<IfModule mod_headers.c>
    # Seiten & Skripte: Browser muss vor Nutzung beim Server rückfragen (ETag → 304 wenn unverändert)
    <FilesMatch "\.(html|php|css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
    # Bilder, Fonts, Icons: dürfen eine Woche gecacht werden
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# UTF-8 sicherstellen
AddDefaultCharset UTF-8

# Sprechende Stadt-Landingpages (SEO): /tagesmutter/<stadt> → stadt.php?stadt=<stadt>
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^tagesmutter/([a-z0-9-]+)/?$ stadt.php?stadt=$1 [L,QSA]
</IfModule>

# Schöne Fehlerseite
ErrorDocument 404 /404.html
